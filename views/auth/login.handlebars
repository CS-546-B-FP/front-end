{{! Reserved page placeholder. Route-level rendering currently uses views/placeholder.handlebars. }}
<section class="auth-page">
  <div class="auth-card">
    <header class="auth-header">
      <p class="eyebrow">Welcome back</p>
      <h1>Sign in to LeaseWise NYC</h1>
      <p class="auth-description">
        Access your watchlist, shortlists, reviews, and saved building comparisons.
      </p>
    </header>

    {{> error-summary errors=errors}}

    <form class="auth-form" id="login-form" action="/auth/login" method="POST" novalidate>
      <div class="form-field">
        <label for="username">Username</label>
        <input
          id="username"
          name="username"
          type="text"
          autocomplete="username"
          placeholder="Enter username"
          required
          value="{{formData.username}}"
        >
      </div>

      <div class="form-field">
        <label for="password">Password</label>
        <input
          id="password"
          name="password"
          type="password"
          autocomplete="current-password"
          placeholder="Enter password"
          required
        >
      </div>

      <button class="button button-primary auth-submit" type="submit">
        Sign in
      </button>
    </form>

    <p class="auth-switch">
      New to LeaseWise NYC?
      <a href="/auth/register">Create an account</a>
    </p>
  </div>
</section>