<section class="placeholder-page">
  <h1>{{page.title}}</h1>
  <p class="page-intro">{{page.description}}</p>
</section>

<section class="placeholder-panel">
  <dl class="placeholder-meta">
    <div>
      <dt>{{t "placeholder.routeLabel"}}</dt>
      <dd><code>{{page.pagePath}}</code></dd>
    </div>
    <div>
      <dt>{{t "placeholder.groupLabel"}}</dt>
      <dd>{{page.routeGroup}}</dd>
    </div>
  </dl>
</section>

<section class="placeholder-panel" aria-labelledby="placeholder-next-heading">
  <h2 id="placeholder-next-heading">{{t "placeholder.planHeading"}}</h2>
  <ul class="todo-list">
    {{#each page.todoItems}}
      <li>{{this}}</li>
    {{/each}}
  </ul>
</section>
