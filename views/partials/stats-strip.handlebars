<div class="stats-strip" role="list" aria-label="{{t "stats.complaints"}}">
  <div class="stats-strip__item" role="listitem">
    <span class="stats-strip__value">{{stats.complaints}}</span>
    <p class="stats-strip__label">{{t "stats.complaints"}}</p>
  </div>
  <div class="stats-strip__item" role="listitem">
    <span class="stats-strip__value">{{stats.violations}}</span>
    <p class="stats-strip__label">{{t "stats.violations"}}</p>
  </div>
  <div class="stats-strip__item" role="listitem">
    <span class="stats-strip__value">{{stats.bedbugs}}</span>
    <p class="stats-strip__label">{{t "stats.bedbugs"}}</p>
  </div>
  <div class="stats-strip__item" role="listitem">
    <span class="stats-strip__value">{{stats.litigations}}</span>
    <p class="stats-strip__label">{{t "stats.litigations"}}</p>
  </div>
</div>
