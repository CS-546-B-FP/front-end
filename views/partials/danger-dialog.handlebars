<div class="dialog-backdrop" id="{{dialogId}}" role="dialog" aria-modal="true" aria-labelledby="{{dialogId}}-title">
  <div class="dialog">
    <h2 class="dialog__title" id="{{dialogId}}-title">{{title}}</h2>
    <p class="dialog__message">{{message}}</p>
    <div class="dialog__actions">
      <button class="button button-ghost" type="button" data-dialog-close="{{dialogId}}">{{t "dialog.cancel"}}</button>
      <form method="POST" action="{{formAction}}">
        {{> csrf-field}}
        {{#if formMethod}}<input type="hidden" name="_method" value="{{formMethod}}" />{{/if}}
        {{#each hiddenFields}}
          <input type="hidden" name="{{this.name}}" value="{{this.value}}" />
        {{/each}}
        <button class="button button-danger" type="submit">{{confirmLabel}}</button>
      </form>
    </div>
  </div>
</div>
