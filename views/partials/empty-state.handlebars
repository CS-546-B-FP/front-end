<div class="empty-state">
  {{#if icon}}<span class="empty-state__icon" aria-hidden="true">{{icon}}</span>{{/if}}
  <h2 class="empty-state__title">{{title}}</h2>
  {{#if message}}<p class="empty-state__message">{{message}}</p>{{/if}}
  {{#if actionHref}}
    <a class="button button-primary" href="{{actionHref}}">{{actionLabel}}</a>
  {{/if}}
</div>
