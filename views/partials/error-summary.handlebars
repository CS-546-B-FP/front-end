{{#if errors.length}}
  <section
    class="error-summary"
    role="alert"
    aria-labelledby="error-summary-title"
    tabindex="-1"
  >
    <h2 id="error-summary-title">There is a problem</h2>

    <ul class="error-summary__list">
      {{#each errors}}
        <li>
          {{#if this.message}}
            {{#if this.href}}
              <a href="{{this.href}}">{{this.message}}</a>
            {{else}}
              {{this.message}}
            {{/if}}
          {{else}}
            {{this}}
          {{/if}}
        </li>
      {{/each}}
    </ul>
  </section>
{{/if}}
