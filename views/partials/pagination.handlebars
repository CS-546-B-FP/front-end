{{!--
  Expected input: pagination = {
    page: 2,
    totalPages: 5,
    hasPrev: true,
    hasNext: true,
    prevPage: 1,
    nextPage: 3
  }
--}}

<nav class="pagination" aria-label="{{t "pagination.nav"}}">

  {{#if pagination}}
    <ul class="pagination__list">

      {{! PREVIOUS }}
      <li class="pagination__item">
        {{#if pagination.hasPrev}}
          <a
            class="pagination__link"
            href="?page={{pagination.prevPage}}{{#if currentQuery.limit}}&limit={{currentQuery.limit}}{{/if}}{{#if currentQuery.search}}&search={{currentQuery.search}}{{/if}}{{#if currentQuery.borough}}&borough={{currentQuery.borough}}{{/if}}{{#if locale}}&lang={{locale}}{{/if}}"
            rel="prev"
          >
            {{t "pagination.prev"}}
          </a>
        {{else}}
          <span class="pagination__link is-disabled">
            {{t "pagination.prev"}}
          </span>
        {{/if}}
      </li>

      {{! CURRENT PAGE }}
      <li class="pagination__item">
        <span
          class="pagination__current"
          aria-current="page"
        >
          {{#if pagination.page}}
            {{t "pagination.page"}} {{pagination.page}}
          {{/if}}
          {{#if pagination.totalPages}}
            / {{pagination.totalPages}}
          {{/if}}
        </span>
      </li>

      {{! NEXT }}
      <li class="pagination__item">
        {{#if pagination.hasNext}}
          <a
            class="pagination__link"
            href="?page={{pagination.nextPage}}{{#if currentQuery.limit}}&limit={{currentQuery.limit}}{{/if}}{{#if currentQuery.search}}&search={{currentQuery.search}}{{/if}}{{#if currentQuery.borough}}&borough={{currentQuery.borough}}{{/if}}{{#if locale}}&lang={{locale}}{{/if}}"
            rel="next"
          >
            {{t "pagination.next"}}
          </a>
        {{else}}
          <span class="pagination__link is-disabled">
            {{t "pagination.next"}}
          </span>
        {{/if}}
      </li>

    </ul>
  {{/if}}

</nav>
